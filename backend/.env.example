# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=5488

# ─── Database (SQLite — file path) ───────────────────────
# Development: file in backend folder
DATABASE_URL="file:./jewelry_store.db"
# Production (Electron): set by main.js to AppData path automatically

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string_min_32_chars
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cloudinary (optional — for cloud image storage) ─────
# Leave blank to store images as base64 locally
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email (optional — for sending invoices) ─────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="JewelStore <noreply@jewelstore.com>"

# ─── Frontend URL ─────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Store Defaults ───────────────────────────────────────
STORE_NAME="My Jewelry Store"
STORE_CURRENCY=INR
STORE_TAX_RATE=3
