generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model StoreSettings {
  id              String   @id @default(uuid())
  storeName       String   @default("My Jewelry Store")
  logoUrl         String?
  address         String?
  city            String?
  state           String?
  country         String?
  phone           String?
  email           String?
  website         String?
  gstNumber       String?
  currency        String   @default("INR")
  currencySymbol  String   @default("₹")
  taxRate         Decimal  @default(3)   @db.Decimal(5,2)
  goldRate        Decimal  @default(0)   @db.Decimal(10,2)
  invoicePrefix   String   @default("INV")
  invoiceFooter   String?
  termsConditions String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@map("store_settings")
}

model User {
  id               String    @id @default(uuid())
  name             String
  email            String    @unique
  password         String
  role             String    @default("SALES_STAFF")
  phone            String?
  avatarUrl        String?
  isActive         Boolean   @default(true)
  twoFactorSecret  String?
  twoFactorEnabled Boolean   @default(false)
  lastLoginAt      DateTime?
  refreshToken     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  sales            Sale[]
  auditLogs        AuditLog[]
  @@map("users")
}

model Category {
  id            String        @id @default(uuid())
  name          String        @unique
  description   String?
  imageUrl      String?
  isActive      Boolean       @default(true)
  sortOrder     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  subCategories SubCategory[]
  inventory     Inventory[]
  @@map("categories")
}

model SubCategory {
  id          String      @id @default(uuid())
  name        String
  description String?
  isActive    Boolean     @default(true)
  categoryId  String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  inventory   Inventory[]
  @@unique([name, categoryId])
  @@map("sub_categories")
}

model Supplier {
  id            String     @id @default(uuid())
  companyName   String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  city          String?
  state         String?
  country       String?
  gstNumber     String?
  bankDetails   String?
  creditLimit   Decimal    @default(0) @db.Decimal(12,2)
  notes         String?
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  purchases     Purchase[]
  inventory     Inventory[]
  @@map("suppliers")
}

model Inventory {
  id            String       @id @default(uuid())
  productId     String       @unique
  barcode       String?      @unique
  qrCode        String?
  name          String
  description   String?
  categoryId    String?
  subCategoryId String?
  collection    String?
  metalType     String       @default("GOLD")
  purity        String       @default("K22")
  weight        Decimal      @db.Decimal(10,3)
  stoneType     String?
  stoneWeight   Decimal?     @db.Decimal(10,3)
  size          String?
  color         String?
  designNumber  String?
  brand         String?
  supplierId    String?
  purchasePrice Decimal      @db.Decimal(12,2)
  makingCharges Decimal      @default(0) @db.Decimal(12,2)
  otherCharges  Decimal      @default(0) @db.Decimal(12,2)
  sellingPrice  Decimal      @db.Decimal(12,2)
  quantity      Int          @default(1)
  minQuantity   Int          @default(1)
  stockStatus   String       @default("IN_STOCK")
  images        String[]
  tags          String[]
  notes         String?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  category      Category?    @relation(fields: [categoryId], references: [id])
  subCategory   SubCategory? @relation(fields: [subCategoryId], references: [id])
  supplier      Supplier?    @relation(fields: [supplierId], references: [id])
  saleItems     SaleItem[]
  purchaseItems PurchaseItem[]
  @@index([categoryId])
  @@index([supplierId])
  @@index([stockStatus])
  @@map("inventory")
}

model Customer {
  id          String           @id @default(uuid())
  customerId  String           @unique
  fullName    String
  phone       String
  whatsapp    String?
  email       String?
  address     String?
  city        String?
  state       String?
  country     String?
  birthday    DateTime?
  anniversary DateTime?
  idProof     String?
  idProofUrl  String?
  photoUrl    String?
  creditLimit Decimal          @default(0) @db.Decimal(12,2)
  notes       String?
  isActive    Boolean          @default(true)
  lastVisitAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  sales       Sale[]
  payments    Payment[]
  balance     CustomerBalance?
  @@index([phone])
  @@map("customers")
}

model CustomerBalance {
  id            String   @id @default(uuid())
  customerId    String   @unique
  totalPurchase Decimal  @default(0) @db.Decimal(12,2)
  totalPaid     Decimal  @default(0) @db.Decimal(12,2)
  balance       Decimal  @default(0) @db.Decimal(12,2)
  creditBalance Decimal  @default(0) @db.Decimal(12,2)
  updatedAt     DateTime @updatedAt
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  @@map("customer_balances")
}

model Sale {
  id            String    @id @default(uuid())
  invoiceNumber String    @unique
  customerId    String
  userId        String
  saleDate      DateTime  @default(now())
  goldRate      Decimal?  @db.Decimal(10,2)
  subTotal      Decimal   @db.Decimal(12,2)
  discountType  String?
  discountValue Decimal   @default(0) @db.Decimal(12,2)
  discountAmount Decimal  @default(0) @db.Decimal(12,2)
  taxRate       Decimal   @default(0) @db.Decimal(5,2)
  taxAmount     Decimal   @default(0) @db.Decimal(12,2)
  grandTotal    Decimal   @db.Decimal(12,2)
  paidAmount    Decimal   @default(0) @db.Decimal(12,2)
  balanceAmount Decimal   @default(0) @db.Decimal(12,2)
  paymentMethod String    @default("CASH")
  paymentStatus String    @default("PENDING")
  status        String    @default("CONFIRMED")
  notes         String?
  dueDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  customer      Customer  @relation(fields: [customerId], references: [id])
  salesperson   User      @relation(fields: [userId], references: [id])
  items         SaleItem[]
  payments      Payment[]
  @@index([customerId])
  @@index([saleDate])
  @@map("sales")
}

model SaleItem {
  id            String    @id @default(uuid())
  saleId        String
  inventoryId   String
  quantity      Int       @default(1)
  weight        Decimal?  @db.Decimal(10,3)
  goldRate      Decimal?  @db.Decimal(10,2)
  stoneCharges  Decimal   @default(0) @db.Decimal(12,2)
  makingCharges Decimal   @default(0) @db.Decimal(12,2)
  unitPrice     Decimal   @db.Decimal(12,2)
  totalPrice    Decimal   @db.Decimal(12,2)
  createdAt     DateTime  @default(now())
  sale          Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  inventory     Inventory @relation(fields: [inventoryId], references: [id])
  @@index([saleId])
  @@map("sale_items")
}

model Payment {
  id            String   @id @default(uuid())
  saleId        String?
  customerId    String
  amount        Decimal  @db.Decimal(12,2)
  paymentMethod String   @default("CASH")
  reference     String?
  notes         String?
  paymentDate   DateTime @default(now())
  createdAt     DateTime @default(now())
  sale          Sale?    @relation(fields: [saleId], references: [id])
  customer      Customer @relation(fields: [customerId], references: [id])
  @@index([customerId])
  @@map("payments")
}

model Purchase {
  id             String         @id @default(uuid())
  purchaseNumber String         @unique
  supplierId     String
  purchaseDate   DateTime       @default(now())
  subTotal       Decimal        @db.Decimal(12,2)
  taxAmount      Decimal        @default(0) @db.Decimal(12,2)
  otherCharges   Decimal        @default(0) @db.Decimal(12,2)
  grandTotal     Decimal        @db.Decimal(12,2)
  paidAmount     Decimal        @default(0) @db.Decimal(12,2)
  balanceAmount  Decimal        @default(0) @db.Decimal(12,2)
  paymentStatus  String         @default("PENDING")
  status         String         @default("PENDING")
  invoiceRef     String?
  notes          String?
  dueDate        DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  supplier       Supplier       @relation(fields: [supplierId], references: [id])
  items          PurchaseItem[]
  @@index([supplierId])
  @@map("purchases")
}

model PurchaseItem {
  id          String    @id @default(uuid())
  purchaseId  String
  inventoryId String
  quantity    Int       @default(1)
  unitCost    Decimal   @db.Decimal(12,2)
  totalCost   Decimal   @db.Decimal(12,2)
  createdAt   DateTime  @default(now())
  purchase    Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  inventory   Inventory @relation(fields: [inventoryId], references: [id])
  @@map("purchase_items")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
  @@index([userId])
  @@index([entity])
  @@map("audit_logs")
}

model Notification {
  id         String   @id @default(uuid())
  type       String
  title      String
  message    String
  entityId   String?
  entityType String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  @@map("notifications")
}
