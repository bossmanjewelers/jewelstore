# Railway sets DATABASE_URL automatically when you add a PostgreSQL plugin.
# You only need to set the JWT secrets manually in Railway dashboard.

NODE_ENV=production
PORT=8080

# Set these in Railway → Variables tab:
# JWT_SECRET=<generate a long random string>
# JWT_REFRESH_SECRET=<generate a different long random string>

# Railway provides this automatically — do NOT set manually:
# DATABASE_URL=postgresql://...

JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
